# ------------------------------------------------------------------------------
# MultiChat environment configuration. Copy to `.env` and fill in the blanks.
# NEVER commit your real .env — it is gitignored.
# ------------------------------------------------------------------------------

# REQUIRED. Fernet key used to encrypt provider/tool secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# REQUIRED for any non-local deployment. Secret for signing JWT access tokens.
# Use a long random string, e.g.: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./chatbot.db

# Allowed CORS origin for the frontend.
FRONTEND_ORIGIN=http://localhost:5000

# Where uploaded images / documents are stored.
UPLOAD_DIR=./uploads

# ------------------------------------------------------------------------------
# Frontend (build/dev time). The Vite app reads this; default http://localhost:5001
# VITE_API_BASE=http://localhost:5001
# ------------------------------------------------------------------------------
